# Review data contains the source under review — never commit it.
# Exception: reviews/sample/ is a curated demo shipped with the repo (first-run content).
reviews/*
!reviews/sample/

# Per-machine Claude Code settings (personal paths / allowlist). The committed
# skills under .claude/skills/ ARE tracked; only the local settings are ignored.
.claude/settings.local.json

node_modules/
dist/
*.log
.DS_Store

# WCC controller runtime state (pidfile + server log) — see bin/wcc-mcp.mjs
.wcc/
